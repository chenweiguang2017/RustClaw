# RustClaw Configuration Example
# Copy this file to .env and fill in your values

# API Configuration
RUSTCLAW_API_KEY=your-api-key-here
RUSTCLAW_MODEL=gpt-4
RUSTCLAW_BASE_URL=https://api.openai.com/v1
RUSTCLAW_PROVIDER=openai

# Rate Limiting (RPM Control)
# Requests per minute limit
RUSTCLAW_RPM=60

# Minimum interval between requests in milliseconds
RUSTCLAW_MIN_INTERVAL_MS=500

# Maximum interval between requests in milliseconds (for random range)
RUSTCLAW_MAX_INTERVAL_MS=2000

# Use random interval within min/max range
RUSTCLAW_RANDOM_INTERVAL=false

# Concurrency Control
# Maximum concurrent API requests
RUSTCLAW_MAX_CONCURRENT_REQUESTS=10

# Maximum concurrent tool executions
RUSTCLAW_MAX_CONCURRENT_TOOLS=5

# Maximum concurrent sessions
RUSTCLAW_MAX_CONCURRENT_SESSIONS=100

# Gateway Configuration
RUSTCLAW_HOST=0.0.0.0
RUSTCLAW_PORT=3000

# Gateway Authentication
RUSTCLAW_GATEWAY_TOKEN=your-gateway-token
RUSTCLAW_GATEWAY_PASSWORD=your-gateway-password

# Logging
RUSTCLAW_LOG_LEVEL=info
